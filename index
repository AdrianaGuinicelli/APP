                <div class="notification-text">${n.text}</div>
                <div class="notification-time"><i class="fas fa-clock"></i> ${n.time}</div>
                ${n.actions?`<div class="notification-actions"><button class="btn btn-success btn-sm" onclick="handleReq(${n.reqId},'accept',this)"><i class="fas fa-check"></i> Accetta</button><button class="btn btn-danger btn-sm" onclick="handleReq(${n.reqId},'decline',this)"><i class="fas fa-times"></i> Declina</button></div>`:''}
                ${n.showSubchat?`<div class="notification-actions"><button class="btn btn-accent btn-sm" onclick="showToast('Sotto-chat aperta!','success')"><i class="fas fa-comments"></i> Apri Sotto-Chat</button></div>`:''}
            </div>
            ${n.unread?'<div style="width:10px;height:10px;background:var(--primary);border-radius:50%;flex-shrink:0;margin-top:4px;"></div>':''}
        </div>`).join('');
}
function markAllRead() { NOTIFICATIONS.forEach(n=>n.unread=false); renderNotifications(); const b=document.getElementById('notifBadge'); if(b)b.style.display='none'; showToast('Tutte le notifiche lette','success'); }

// ============================================================
// CHAT
// ============================================================
function renderChats() {
    const c = document.getElementById('chatListContainer'); if(!c) return;
    c.innerHTML = CHATS.map(ch=>`
        <div class="chat-item ${ch.id===App.activeChat?'active':''}" onclick="openChat(${ch.id})">
            <div style="width:44px;height:44px;background:linear-gradient(135deg,var(--primary),var(--secondary));border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">${ch.emoji}</div>
            <div class="chat-item-info"><div class="chat-item-name">${ch.name}</div><div class="chat-item-preview">${ch.lastMsg}</div></div>
            <div class="chat-item-meta"><div class="chat-time">${ch.time}</div>${ch.unread>0?`<div class="chat-unread">${ch.unread}</div>`:''}</div>
        </div>`).join('');
}
function openChat(id) {
    App.activeChat = id;
    const ch = CHATS.find(c=>c.id===id); if(!ch) return;
    document.querySelectorAll('.chat-item').forEach(c=>c.classList.remove('active'));
    const items = document.querySelectorAll('.chat-item');
    const idx = CHATS.findIndex(c=>c.id===id);
    if(items[idx]) items[idx].classList.add('active');
    document.getElementById('chatTitle').textContent = ch.name;
    document.getElementById('chatSubtitle').textContent = `● Chat evento: ${ch.event}`;
    const mc = document.getElementById('chatMessages');
    mc.innerHTML = ch.messages.map(m=>`<div style="max-width:65%;${m.own?'align-self:flex-end;flex-direction:row-reverse;':''}display:flex;gap:8px;"><div class="avatar avatar-sm" style="background:${m.color};flex-shrink:0;">${m.avatar}</div><div>${!m.own?`<div class="message-sender">${m.sender}</div>`:''}<div style="padding:10px 14px;border-radius:${m.own?'var(--radius) 4px var(--radius) var(--radius)':'4px var(--radius) var(--radius) var(--radius)'};background:${m.own?'var(--primary)':'white'};color:${m.own?'white':'var(--dark)'};font-size:13px;box-shadow:0 1px 4px rgba(0,0,0,0.1);">${m.text}</div><div style="font-size:10px;color:var(--gray);margin-top:4px;text-align:${m.own?'right':'left'};">${m.time}</div></div></div>`).join('');
    mc.scrollTop = mc.scrollHeight;
    ch.unread = 0; renderChats();
}
function sendMessage() {
    const input = document.getElementById('chatInputField');
    const text  = input.value.trim();
    if (!text || !App.activeChat) return;
    const ch = CHATS.find(c=>c.id===App.activeChat); if(!ch) return;
    const now = new Date().toLocaleTimeString('it-IT',{hour:'2-digit',minute:'2-digit'});
    const mc  = document.getElementById('chatMessages');
    const el  = document.createElement('div');
    el.style.cssText = 'max-width:65%;align-self:flex-end;flex-direction:row-reverse;display:flex;gap:8px;';
    el.innerHTML = `<div class="avatar avatar-sm" style="background:#003580;flex-shrink:0;">M</div><div><div style="padding:10px 14px;border-radius:var(--radius) 4px var(--radius) var(--radius);background:var(--primary);color:white;font-size:13px;box-shadow:0 1px 4px rgba(0,0,0,0.1);">${text}</div><div style="font-size:10px;color:var(--gray);margin-top:4px;text-align:right;">${now}</div></div>`;
    mc.appendChild(el); mc.scrollTop=mc.scrollHeight;
    input.value = '';
    ch.messages.push({sender:"Tu",avatar:"M",color:"#003580",text,time:now,own:true});
    ch.lastMsg = "Tu: "+text; ch.time="Adesso";
    const replies = ["Ottimo! 👍","Perfetto, ci vediamo lì! 🎉","Grazie!","Non vedo l'ora 🚀","Conferma anche tu! ✅"];
    setTimeout(()=>{
        const rt  = replies[Math.floor(Math.random()*replies.length)];
        const rn  = new Date().toLocaleTimeString('it-IT',{hour:'2-digit',minute:'2-digit'});
        const rel = document.createElement('div');
        rel.style.cssText = 'max-width:65%;display:flex;gap:8px;';
        rel.innerHTML = `<div class="avatar avatar-sm" style="background:#30cfd0;flex-shrink:0;">A</div><div><div class="message-sender">${ch.name.split('–')[0].trim()}</div><div style="padding:10px 14px;border-radius:4px var(--radius) var(--radius) var(--radius);background:white;color:var(--dark);font-size:13px;box-shadow:0 1px 4px rgba(0,0,0,0.1);">${rt}</div><div style="font-size:10px;color:var(--gray);margin-top:4px;">${rn}</div></div>`;
        mc.appendChild(rel); mc.scrollTop=mc.scrollHeight;
    },1500);
}

// ============================================================
// FILTERS
// ============================================================
function filterEvents() { const s=document.getElementById('searchInput').value.toLowerCase(); renderExploreEvents(EVENTS.filter(e=>e.title.toLowerCase().includes(s)||e.city.toLowerCase().includes(s)||e.category.toLowerCase().includes(s)||e.tags.some(t=>t.includes(s)))); }
function filterByCategory(cat,el) { document.querySelectorAll('.chip').forEach(c=>c.classList.remove('active')); el.classList.add('active'); renderExploreEvents(cat==='all'?EVENTS:EVENTS.filter(e=>e.tags.includes(cat))); }
function applyFilters() {
    const city = document.getElementById('filterCity').value.toLowerCase();
    const maxP = parseInt(document.getElementById('filterPrice').value);
    const from = document.getElementById('filterDateFrom').value;
    const filtered = EVENTS.filter(e=>{
        if(city && !e.city.toLowerCase().includes(city)) return false;
        if(e.price > maxP) return false;
        if(from && e.date < from) return false;
        return true;
    });
    renderExploreEvents(filtered);
    showToast(`Filtri applicati: ${filtered.length} eventi trovati`,'success');
}
function sortEvents(by) {
    const s = [...EVENTS];
    if(by==='price_asc')  s.sort((a,b)=>a.price-b.price);
    else if(by==='price_desc') s.sort((a,b)=>b.price-a.price);
    else if(by==='date')  s.sort((a,b)=>new Date(a.date)-new Date(b.date));
    else if(by==='popular') s.sort((a,b)=>b.participants.length-a.participants.length);
    renderExploreEvents(s);
}

// ============================================================
// FAVORITES
// ============================================================
function toggleFav(id, btn) {
    const ev = EVENTS.find(e=>e.id===id); if(!ev) return;
    ev.favorited = !ev.favorited;
    const i = btn.querySelector('i');
    if(ev.favorited){ i.className='fas fa-heart'; i.style.color='var(--danger)'; App.favorites.push(ev); showToast('Aggiunto ai preferiti ❤️','success'); }
    else { i.className='far fa-heart'; i.style.color='var(--gray)'; App.favorites=App.favorites.filter(f=>f.id!==id); showToast('Rimosso dai preferiti','info'); }
    renderFavorites();
}

// ============================================================
// EVENT CREATION
// ============================================================
function togglePriceField(sel) { document.getElementById('priceFieldWrap').style.display = sel.value!=='free'?'block':'none'; }
function importFromUrl() {
    const url = document.getElementById('importUrl').value; if(!url){showToast('Inserisci un URL valido','error');return;}
    showLoading(); setTimeout(()=>{ hideLoading(); try{ document.getElementById('evTitle').value="Evento da "+new URL(url).hostname; }catch(e){} document.getElementById('evDescription').value="Descrizione importata."; document.getElementById('evAddress').value="Milano"; showToast('Dati importati ✅','success'); },1500);
}
function saveDraftEvent() { showToast('Bozza salvata 📝','info'); closeModal('createEventModal'); }
function publishEvent() {
    const t=document.getElementById('evTitle').value.trim();
    const ca=document.getElementById('evCategory').value;
    const d=document.getElementById('evDescription').value.trim();
    const ds=document.getElementById('evDateStart').value;
    const a=document.getElementById('evAddress').value.trim();
    if(!t){showToast("Inserisci il nome dell'evento",'error');return;}
    if(!ca){showToast('Seleziona una categoria','error');return;}
    if(!d){showToast('Aggiungi una descrizione','error');return;}
    if(!ds){showToast("Seleziona la data dell'evento",'error');return;}
    if(!a){showToast("Inserisci l'indirizzo",'error');return;}
    showLoading(); setTimeout(()=>{ hideLoading(); closeModal('createEventModal'); showToast('Evento pubblicato! 🎉','success'); },1500);
}

// ============================================================
// PROFILE
// ============================================================
function saveProfile() { showLoading(); setTimeout(()=>{ hideLoading(); closeModal('editProfileModal'); showToast('Profilo aggiornato ✅','success'); },1000); }
function triggerPhotoUpload() { showToast('Scegli una foto dal tuo dispositivo 📷','info'); }

// ============================================================
// UTILITIES
// ============================================================
function showLoading()  { document.getElementById('loadingOverlay').classList.remove('hidden'); }
function hideLoading()  { document.getElementById('loadingOverlay').classList.add('hidden'); }
function showToast(msg, type='success') {
    const icons  = {success:'fas fa-check-circle',error:'fas fa-exclamation-circle',warning:'fas fa-exclamation-triangle',info:'fas fa-info-circle'};
    const colors = {success:'var(--success)',error:'var(--danger)',warning:'var(--warning)',info:'var(--secondary)'};
    const t = document.createElement('div');
    t.className = `toast ${type!=='success'?type:''}`;
    t.innerHTML = `<i class="${icons[type]}" style="color:${colors[type]};font-size:20px;"></i><span class="toast-text">${msg}</span><button onclick="this.parentElement.remove()" style="background:none;border:none;cursor:pointer;font-size:16px;color:var(--gray);padding:0 4px;">✕</button>`;
    document.getElementById('toastContainer').appendChild(t);
    setTimeout(()=>{ if(t.parentElement) t.remove(); },4000);
}
</script>
