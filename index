// ============================================================
// REGISTRATION
// ============================================================
let regStep = 1;
const REG_TOTAL = 5;

function nextRegStep() {
    if (!validateRegStep(regStep)) return;
    if (regStep === 2 && !App.selfieVerified) { showToast('Completa la verifica selfie prima di continuare','error'); return; }
    if (regStep === REG_TOTAL) { finishReg(); return; }
    goRegStep(regStep + 1);
}
function prevRegStep() { if (regStep > 1) goRegStep(regStep - 1); }

function goRegStep(step) {
    document.getElementById('regStep' + regStep).classList.add('hidden');
    const oldEl = document.getElementById('step-' + regStep);
    oldEl.classList.remove('active'); oldEl.classList.add('completed');
    oldEl.querySelector('.step-circle').innerHTML = '✓';
    const line = document.getElementById(`line-${regStep}-${regStep+1}`);
    if (line && step > regStep) line.classList.add('completed');
    if (regStep === 2) stopCamera('reg');
    regStep = step;
    document.getElementById('regStep' + regStep).classList.remove('hidden');
    const newEl = document.getElementById('step-' + regStep);
    newEl.classList.add('active'); newEl.classList.remove('completed');
    const prev = document.getElementById('regPrevBtn');
    const next = document.getElementById('regNextBtn');
    const skip = document.getElementById('regSkipBtn');
    prev.style.display = regStep > 1 ? 'flex' : 'none';
    next.innerHTML = regStep === REG_TOTAL ? '<i class="fas fa-rocket"></i> Inizia!' : 'Continua <i class="fas fa-arrow-right"></i>';
    skip.style.display = regStep === 2 ? 'none' : (regStep >= 3 ? 'inline-flex' : 'none');
}

function validateRegStep(step) {
    if (step === 1) {
        const fn = document.getElementById('regFirstName').value.trim();
        const ln = document.getElementById('regLastName').value.trim();
        const em = document.getElementById('regEmail').value.trim();
        const bd = document.getElementById('regBirthDate').value;
        const gn = document.getElementById('regGender').value;
        const pw = document.getElementById('regPassword').value;
        const pc = document.getElementById('regPasswordConfirm').value;
        const tc = document.getElementById('regTerms').checked;
        if (!fn || !ln) { showToast('Inserisci nome e cognome','error'); return false; }
        if (!em || !em.includes('@')) { showToast("Inserisci un'email valida",'error'); return false; }
        if (!bd) { showToast('Inserisci la data di nascita','error'); return false; }
        if (!checkAgeValid(bd)) { showToast('Devi avere almeno 18 anni','error'); return false; }
        if (!gn) { showToast('Seleziona il genere','error'); return false; }
        if (pw.length < 8) { showToast('Password: minimo 8 caratteri','error'); return false; }
        if (pw !== pc) { showToast('Le password non coincidono','error'); return false; }
        if (!tc) { showToast('Accetta i Termini di Servizio','error'); return false; }
    }
    return true;
}
function checkAge(input) { document.getElementById('ageWarning').style.display = checkAgeValid(input.value) ? 'none' : 'block'; }
function checkAgeValid(d) {
    if (!d) return false;
    const b = new Date(d), t = new Date();
    return t.getFullYear() - b.getFullYear() - (t < new Date(t.getFullYear(), b.getMonth(), b.getDate()) ? 1 : 0) >= 18;
}
