// SELFIE / LIVENESS  — unified by prefix: 'reg' | 'verify'
// ============================================================
const IDS = {
    reg:    { container:'regSelfieContainer',    video:'regSelfieVideo',    canvas:'regSelfieCanvas',    guide:'regFaceGuide',    hint:'regSelfieHint',    captured:'regSelfieCaptured',    bar:'regLivenessBar',    pct:'regLivenessPct',    startBtn:'regStartCamBtn', captureBtn:'regCaptureBtn', retakeBtn:'regRetakeBtn', lsPrefix:'rls-' },
    verify: { container:'verifySelfieContainer', video:'verifySelfieVideo', canvas:'verifySelfieCanvas', guide:'verifyFaceGuide', hint:'verifySelfieHint', captured:'verifySelfieCaptured', bar:'verifyLivenessBar', pct:'verifyLivenessPct', startBtn:'verifyStartBtn',  captureBtn:'verifyCaptureBtn',  retakeBtn:'verifyRetakeBtn',  lsPrefix:'vls-' }
};

function startSelfie(prefix) {
    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) { showToast('Fotocamera non supportata. Usa Chrome o Firefox.','error'); return; }
    const cfg = IDS[prefix];
    navigator.mediaDevices.getUserMedia({ video:{facingMode:'user',width:{ideal:640},height:{ideal:480}}, audio:false })
        .then(stream => {
            App.selfieStreams[prefix] = stream;
            document.getElementById(cfg.video).srcObject = stream;
            document.getElementById(cfg.startBtn).classList.add('hidden');
            runLiveness(prefix);
        })
        .catch(err => showToast('Fotocamera non accessibile: ' + err.message,'error'));
}

function runLiveness(prefix) {
    const cfg = IDS[prefix];
    function setStep(n) {
        for (let i=1;i<=5;i++) {
            const el = document.getElementById(cfg.lsPrefix+i);
            if (!el) continue;
            el.classList.remove('active','done');
            if (i < n) el.classList.add('done');
            if (i === n) el.classList.add('active');
        }
    }
    function setBar(v) { const b=document.getElementById(cfg.bar); const p=document.getElementById(cfg.pct); if(b)b.style.width=v+'%'; if(p)p.textContent=v+'%'; }
    setStep(1); setBar(10);
    setTimeout(()=>{ setStep(2); setBar(30); const h=document.getElementById(cfg.hint); if(h)h.textContent='Volto rilevato ✓ — rimani fermo'; const g=document.getElementById(cfg.guide); if(g)g.classList.add('detecting'); },800);
    setTimeout(()=>{ setStep(3); setBar(60); const h=document.getElementById(cfg.hint); if(h)h.textContent='Verifica liveness in corso...'; },1800);
    setTimeout(()=>{
        setStep(4); setBar(85);
        const g=document.getElementById(cfg.guide); if(g){g.classList.remove('detecting');g.classList.add('ok');}
        const h=document.getElementById(cfg.hint); if(h)h.textContent='✓ Pronto! Premi "Scatta Selfie"';
        document.getElementById(cfg.captureBtn).classList.remove('hidden');
        document.getElementById(cfg.startBtn).classList.add('hidden');
        if (prefix==='verify') document.getElementById('verifySubmitBtn').classList.add('hidden');
    },3200);
}

function captureSelfie(prefix) {
    const cfg = IDS[prefix];
    const video  = document.getElementById(cfg.video);
    const canvas = document.getElementById(cfg.canvas);
    canvas.width = video.videoWidth||640; canvas.height = video.videoHeight||480;
    const ctx = canvas.getContext('2d');
    ctx.save(); ctx.scale(-1,1); ctx.drawImage(video,-canvas.width,0,canvas.width,canvas.height); ctx.restore();
    const img = document.getElementById(cfg.captured);
    img.src = canvas.toDataURL('image/jpeg',0.85); img.style.display='block';
    stopCamera(prefix);
    document.getElementById(cfg.container).style.display='none';
    const ls5 = document.getElementById(cfg.lsPrefix+'5'); if(ls5){ls5.classList.add('done');ls5.classList.remove('active');}
    const b=document.getElementById(cfg.bar); if(b)b.style.width='100%';
    const p=document.getElementById(cfg.pct); if(p)p.textContent='100%';
    document.getElementById(cfg.captureBtn).classList.add('hidden');
    document.getElementById(cfg.retakeBtn).classList.remove('hidden');
    if (prefix==='verify') document.getElementById('verifySubmitBtn').classList.remove('hidden');
    App.selfieVerified = true;
    showToast('Selfie acquisito con successo! ✅','success');
}

function retakeSelfie(prefix) {
    const cfg = IDS[prefix];
    App.selfieVerified = false;
    document.getElementById(cfg.container).style.display='block';
    document.getElementById(cfg.captured).style.display='none';
    document.getElementById(cfg.retakeBtn).classList.add('hidden');
    document.getElementById(cfg.captureBtn).classList.add('hidden');
    document.getElementById(cfg.startBtn).classList.remove('hidden');
    if (prefix==='verify') document.getElementById('verifySubmitBtn').classList.add('hidden');
    const g=document.getElementById(cfg.guide); if(g)g.className='face-guide';
    const h=document.getElementById(cfg.hint); if(h)h.textContent="Posiziona il viso nell'ovale";
    const b=document.getElementById(cfg.bar); if(b)b.style.width='0%';
    const p=document.getElementById(cfg.pct); if(p)p.textContent='0%';
    for(let i=1;i<=5;i++){const el=document.getElementById(cfg.lsPrefix+i);if(el)el.classList.remove('active','done');}
}

function stopCamera(prefix) {
    const s = App.selfieStreams[prefix];
    if (s) { s.getTracks().forEach(t=>t.stop()); delete App.selfieStreams[prefix]; }
}
function stopAllCameras() { ['reg','verify'].forEach(stopCamera); }

function submitVerification() {
    if (!App.selfieVerified) { showToast('Scatta prima il selfie','error'); return; }
    showLoading();
    setTimeout(()=>{
