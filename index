function renderCities(results, container, inputId, suggId) {
    if (!results.length) { container.innerHTML = `<div class="city-suggestion-item" style="cursor:default;color:var(--gray);"><i class="fas fa-search"></i> Nessuna città trovata</div>`; return; }
    container.innerHTML = results.map(c => {
        const flag = FLAGS[c.country] || '🌍';
        const sub  = [c.state, c.country].filter(Boolean).join(', ');
        return `<div class="city-suggestion-item" onclick="selectCity('${c.name.replace(/'/g,"\\'")}','${inputId}','${suggId}')"><span style="font-size:16px;">${flag}</span><span class="city-name">${c.name}</span><span class="city-region">${sub}</span></div>`;
    }).join('');
}

function selectCity(name, inputId, suggId) {
    const el = document.getElementById(inputId);
    if (el) el.value = name;
    const c  = document.getElementById(suggId);
    if (c) closeSugg(c);
}
