const cityCache = {};
let cityDebounceTimer = null;

function cityAutocomplete(inputEl, suggId) {
    const query = inputEl.value.trim();
    const container = document.getElementById(suggId);
    if (!container) return;
    if (query.length < 2) { closeSugg(container); return; }

    container.innerHTML = `<div class="city-suggestion-item" style="cursor:default;color:var(--gray);"><i class="fas fa-circle-notch fa-spin" style="color:var(--secondary);"></i> Ricerca in corso...</div>`;
    container.classList.add('open');

    clearTimeout(cityDebounceTimer);
    cityDebounceTimer = setTimeout(() => fetchCities(query, container, inputEl.id, suggId), 350);
}

function fetchCities(query, container, inputId, suggId) {
    const key = query.toLowerCase();
    if (cityCache[key]) { renderCities(cityCache[key], container, inputId, suggId); return; }

    const url = `https://photon.komoot.io/api/?q=${encodeURIComponent(query)}&limit=8&lang=it&osm_tag=place:city&osm_tag=place:town&osm_tag=place:village`;
    fetch(url)
        .then(r => { if (!r.ok) throw new Error(); return r.json(); })
        .then(data => {
            const results = (data.features || [])
                .filter(f => f.properties && f.properties.name)
                .map(f => ({ name: f.properties.name, country: f.properties.country || '', state: f.properties.state || f.properties.county || '' }))
                .filter((item, i, arr) => arr.findIndex(x => x.name === item.name && x.country === item.country) === i);
            cityCache[key] = results;
            renderCities(results, container, inputId, suggId);
        })
        .catch(() => {
            container.innerHTML = `<div class="city-suggestion-item" style="cursor:default;color:var(--danger);"><i class="fas fa-exclamation-triangle"></i> Errore di connessione. Digita manualmente.</div>`;
        });
}

